# =====================================================
# 環境変数設定ファイル
# このファイルを .env としてコピーし、実際の値を入れる
# =====================================================

# --- Gemini API ---
# https://aistudio.google.com で取得（AIzaSy...で始まる）
GEMINI_API_KEY=your_gemini_api_key_here

# --- Discord Webhook URLs: 銘柄別チャンネル ---
# 各チャンネルの設定 → 連携サービス → ウェブフック で取得
WEBHOOK_WHEAT=https://discord.com/api/webhooks/xxxxx/yyyyy
WEBHOOK_GOLD=https://discord.com/api/webhooks/xxxxx/yyyyy
WEBHOOK_OIL=https://discord.com/api/webhooks/xxxxx/yyyyy
WEBHOOK_CORN=https://discord.com/api/webhooks/xxxxx/yyyyy
WEBHOOK_SOY=https://discord.com/api/webhooks/xxxxx/yyyyy
WEBHOOK_COPPER=https://discord.com/api/webhooks/xxxxx/yyyyy

# --- Discord Webhook URLs: 確信度ルーティング用チャンネル ---
# |確信度| >= 60 のシグナル（最重要アラート）
WEBHOOK_CRITICAL=https://discord.com/api/webhooks/xxxxx/yyyyy
# TAとニュース方向が逆向き（ダイバージェンス = トレード機会）
WEBHOOK_DIVERGENCE=https://discord.com/api/webhooks/xxxxx/yyyyy
# 15 <= |確信度| < 30 の参考情報（ミュート推奨チャンネル）
